# ---------------------------------------------------------------------------
# SolGuard environment configuration (Solinfra). Copy to `.env` and fill in.
# No secrets are committed (see .gitignore). NFR-6: all config via env vars.
# Get Solinfra keys at https://fra.rpc.solinfra.dev/keys
# ---------------------------------------------------------------------------

# --- Solana RPC (Solinfra) ---
# Standard RPC used for blockhash, leader schedule, tip accounts.
# Get an rpc_ key from https://fra.rpc.solinfra.dev/keys
RPC_HTTP_URL=https://fra.rpc.solinfra.dev/sol?api_key=
RPC_WS_URL=wss://fra.rpc.solinfra.dev/sol?api_key=

# --- Yellowstone / Geyser gRPC (source of truth for landing) ---
# Solinfra Geyser endpoint. x-token must be a grpc_ key.
YELLOWSTONE_GRPC_URL=https://fra.grpc.solinfra.dev:443
YELLOWSTONE_X_TOKEN=

# --- Solinfra REST API ---
# Used for balances, transaction history, parsed data, etc.
# Get an sk_ key from https://fra.rpc.solinfra.dev/keys
SOLINFRA_API_KEY=

# --- Jito Block Engine ---
# Regional endpoint base, e.g.:
#   https://amsterdam.mainnet.block-engine.jito.wtf
#   https://frankfurt.mainnet.block-engine.jito.wtf
#   https://ny.mainnet.block-engine.jito.wtf
#   https://tokyo.mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=https://frankfurt.mainnet.block-engine.jito.wtf
# Optional comma-separated fallbacks (0-2 max per plan §5.5)
JITO_BLOCK_ENGINE_FALLBACKS=
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor

# --- Wallet (minimal hot wallet — NFR-7) ---
# Base58-encoded secret key. Keep funded with the bare minimum.
WALLET_SECRET_KEY=

# --- Anthropic (AI agent) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Network selection ---
# mainnet-beta | devnet
SOLANA_CLUSTER=mainnet-beta

# --- Tip safety (NFR-7 / FR-9) ---
# Hard ceiling in lamports the tip model may NEVER exceed. This is a safety
# rail, NOT a tip value — the tip itself is always derived from tip_floor.
TIP_CEILING_LAMPORTS=100000

# --- Stream tuning ---
STREAM_QUEUE_MAX=10000           # bounded queue capacity (FR-5)
STREAM_REPLAY_WINDOW_SLOTS=150   # dedupe / fromSlot replay window
STREAM_PING_INTERVAL_MS=15000    # keepalive cadence (FR-4)
CONGESTION_RING_SIZE=64          # slots tracked by the congestion oracle
