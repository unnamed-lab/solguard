{
  "name": "solguard",
  "version": "0.1.0",
  "description": "SolGuard — Autonomous Bundle Intelligence Stack for Solana (Jito bundles + Yellowstone stream + AI retry agent)",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "live": "tsx src/live.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "stream": "tsx src/stream/probe.ts",
    "bundle:dry": "tsx src/bundle/dry-run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:tips": "node scripts/check-no-hardcoded-tips.mjs",
    "fault:test": "tsx scripts/fault-test.ts",
    "fault:test:evidence": "tsx scripts/fault-test.ts --evidence",
    "test:submit": "tsx scripts/test-submit.ts",
    "test:submit:swap": "tsx scripts/test-submit.ts -- --swap",
    "test:agent": "tsx scripts/test-agent-mainnet.ts",
    "test:trading": "tsx scripts/test-trading-scenarios.ts",
    "test:requote": "tsx scripts/test-requote-retry.ts",
    "test:sniper": "tsx scripts/test-sniper.ts",
    "test:budget": "tsx scripts/test-tip-budget.ts",
    "test:sandwich": "tsx scripts/test-sandwich-guard.ts",
    "server": "tsx src/server.ts",
    "server:watch": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@solana/web3.js": "^1.95.4",
    "@triton-one/yellowstone-grpc": "^1.3.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  }
}
