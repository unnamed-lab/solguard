{
  "name": "solguard",
  "version": "0.1.0",
  "description": "SolGuard — Autonomous Bundle Intelligence Stack for Solana (Jito bundles + Yellowstone stream + AI retry agent)",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "stream": "tsx src/stream/probe.ts",
    "lint:tips": "node scripts/check-no-hardcoded-tips.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@solana/web3.js": "^1.95.4",
    "@triton-one/yellowstone-grpc": "^1.3.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
